--- !u!114 &2043491983
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2043491979}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 5f7201a12d95ffc409449d95f23cf332, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 12800000, guid: e51f7629caa698546a1cebf090b81be6, type: 3}
    m_FontSize: 20
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 0
    m_MaxSize: 40
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "\u672C\u9762\u677F\u4E3B\u7528\u4E8E\u63A5\u6536\u6240\u6709\u7684\u526F\u9762\u677F\u7684\u4FE1\u606F\u5E76\u4E14\u7EDF\u548C\u53D1\u9001\u5230\u76F8\u673A\u7CFB\u7EDF\u4E2D\uFF0C\u662F\u6574\u4E2A\u5BFC\u64AD\u7CFB\u7EDF\u7684\u6838\u5FC3\n\n\u5BFC\u64AD\u7CFB\u7EDF\u5C06\u6BCF\u4E00\u4E2A\u76F8\u673A\u53CA\u5176\u9644\u5C5E\u70B9\u4F4D\uFF0C\u811A\u672C\u79F0\u4E4B\u4E3A\u201C\u76F8\u673A\u7CFB\u7EDF\u201D\u800C\u672C\u9762\u677F\u8D1F\u8D23\u5C06\u60A8\u7684\u64CD\u4F5C\u8BBE\u7F6E\u5230\u201C\u76F8\u673A\u7CFB\u7EDF\u201D\u4E2D\u3002\n\n\u8F93\u51FA\u7CFB\u7EDF\uFF1A\u6307\u7684\u662F\u8F93\u51FA\u76F8\u673A\u4E0B\u7684\u4E0B\u62C9\u9762\u677F\uFF0C\u53F3\u4FA7\u7684\u753B\u9762\uFF0C\u4EE5\u53CA\u5DE6\u4FA7\u7684\u9ED1\u7403\uFF08\u5168\u5C4F\u6750\u8D28\u7528\u4E8EVRC\u76F8\u673A\u8F93\u51FA\uFF09\u3002\u4F60\u53EF\u4EE5\u5728\u901A\u8FC7\u4E0B\u62C9\u9762\u677F\u6765\u63A7\u5236\u53F3\u4FA7\u7684\u753B\u9762\u7684\u6750\u8D28\uFF0C\u4EE5\u53CA\u5DE6\u4FA7\u7684\u9ED1\u7403\u7A76\u7ADF\u663E\u793A\u54EA\u4E2A\u76F8\u673A\u7684\u753B\u9762\n\n\u8BBE\u7F6E\u7CFB\u7EDF\uFF1A\u7531\u76F8\u673A\u9884\u89C8\uFF0C\u6A21\u5F0F\u9009\u62E9\uFF0C\u76F8\u673A\u70B9\u4F4D\uFF0C\u5207\u6362\u8FFD\u8E2A\uFF0C\u8FFD\u8E2A\u8865\u507F\u56DB\u4E2A\u5C5E\u6027\u52A0\u4E00\u4E2A\u786E\u8BA4\u952E\u7EC4\u6210\n\n\u5982\u679C\u4F60\u8981\u5C06\u4E00\u4E2A\u6444\u50CF\u673A\u8BBE\u7F6E\u5230A\u70B9\uFF0C\u5047\u8BBEA\u70B9\u4F4D\u7684\u4F4D\u7F6E\u4E3A\u9501\u8F74\u8DDF\u8E2A\u6A21\u5F0F\uFF0C0\u70B9\u4F4D\uFF0C\u90A3\u4E48\u4F60\u9700\u8981\uFF1A\n1\uFF1A\u5728\u76F8\u673A\u9884\u89C8\u4E2D\u9009\u62E9\u76F8\u673A\uFF08\u76F8\u673A\u53EF\u4EE5\u6709\u5F88\u591A\u4E2A\uFF09\n2\uFF1A\u8BBE\u7F6E\u6A21\u5F0F\u4E3A\u56FA\u5B9A\u8FFD\u8E2A\uFF08\u6A21\u5F0F\u56FA\u5B9A\u4E3A7\u4E2A\uFF0C\u53EF\u6539\u540D\uFF09\n3\uFF1A\u8BBE\u7F6E\u70B9\u4F4D\u4E3A0\n4\uFF1A\u70B9\u51FB\u786E\u8BA4\n\n\u6A21\u5F0F\u5728\u672C\u7CFB\u7EDF\u7684\u610F\u4E49\u4EC5\u4E3A\u5206\u7C7B\uFF0C\u5B9E\u9645\u4E0A\u53EF\u4EE5\u81EA\u7531\u8BBE\u7F6E\n\n\u6296\u52A8\u8865\u507F\uFF1A\u662F\u5426\u5F00\u542F\u9632\u6296\u6A21\u5F0F\n\uFF08\u7A0B\u5EA6\u53EF\u81EA\u5B9A\u4E49\uFF0C\u540C\u76F8\u673A\u4E14\u540C\u4E00\u6A21\u5F0F\u7684\u70B9\u4F4D\u5171\u4EAB\u7A0B\u5EA6\uFF09\n\n\u5207\u6362\u8FFD\u8E2A\uFF1A\u53EF\u624B\u52A8\u8F93\u5165\u540D\u5B57\u6765\u5207\u6362\u5355\u76F8\u673A\u7684\u8FFD\u8E2A\u5BF9\u8C61\n\uFF08\u6BCF\u4E00\u4E2A\u76F8\u673A\u7CFB\u7EDF\u7684\u8FFD\u8E2A\u5BF9\u8C61\u90FD\u662F\u72EC\u7ACB\u7684\uFF09\n\u4E0B\u4E00\u6B21\u6309\u786E\u8BA4\u7684\u65F6\u5019\u5C1D\u8BD5\u5207\u6362\u8FFD\u8E2A\u5BF9\u8C61"
